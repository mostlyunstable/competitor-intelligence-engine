# PostgreSQL (used by docker-compose)
POSTGRES_USER=utservio
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=utservio_ci
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (used by docker-compose)
REDIS_PORT=6379

# Application
CI_APP_PORT=8000
CI_WORKERS=1
CI_LOG_LEVEL=info
CI_DEBUG=false
CI_ENVIRONMENT=development

# Database URL (used by app via CI_DATABASE__URL or constructed from POSTGRES_* in docker-compose)
DATABASE_URL=postgresql+asyncpg://utservio:changeme_in_production@localhost:5432/utservio_ci
CI_DATABASE__URL=postgresql+asyncpg://utservio:changeme_in_production@localhost:5432/utservio_ci

# API Key (required for production, leave empty for development)
CI_API_KEY=

# Collection defaults
CI_COLLECTOR__MAX_CONCURRENT_REQUESTS=10
CI_COLLECTOR__COLLECTION_TIMEOUT=300
CI_COLLECTOR__RATE_LIMIT_PER_SECOND=0.5
CI_COLLECTOR__USER_AGENT=UtservioCI/1.0
CI_COLLECTOR__RETRY_ATTEMPTS=3
CI_COLLECTOR__RETRY_DELAY=1.0

# Scheduler
CI_SCHEDULER__ENABLED=true
CI_SCHEDULER__CHECK_INTERVAL_SECONDS=60

# Competitor configuration path
CI_COMPETITORS_CONFIG_PATH=./competitors.json

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/home/appuser/.cache/ms-playwright
# AI / LLM Fallback (optional — disabled by default)
CI_LLM__ENABLED=false
CI_LLM__PROVIDER=nvidia
CI_LLM__API_KEY=your-api-key-here
CI_LLM__MODEL_NAME=meta/llama3-70b-instruct
CI_LLM__MAX_TOKENS=512
CI_LLM__TEMPERATURE=0.1

# Webhook Alerts (optional — disabled by default)
CI_WEBHOOK__ENABLED=false
CI_WEBHOOK__SLACK_WEBHOOK_URL=
CI_WEBHOOK__TEAMS_WEBHOOK_URL=
